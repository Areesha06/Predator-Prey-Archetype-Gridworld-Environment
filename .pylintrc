[MASTER]
# core/ is maintainers-only (CONTRIBUTING.md "Golden Rule") and is guarded by
# the core-guard CI job on PR diffs, not by student-facing style linting.
ignore=__pycache__,tests,miscellenous,slides,core

[MESSAGES CONTROL]
# C0114/C0115/C0116: this repo's style is short one-line summaries in the
#   module/class docstring, not per-function docstrings on every plugin.
# duplicate-code: observation/action plugins intentionally share near-
#   identical scaffolding (see absolute.py/relative.py, cross_actions.py/
#   discrete_actions.py) so students can add a new plugin by copying an
#   existing one; de-duplicating would mean a shared base students must
#   also learn, which conflicts with the "extend, don't reuse" plugin model.
# protected-access: observations/rewards read Agent._agent_location and
#   GridWorldEnv._obstacle_location by design (see base.py docstrings:
#   "Use only public agent attributes and positions" refers to *not
#   moving* agents, not to avoiding the position field itself) — there is
#   no public accessor for these today.
# too-many-locals: flagged on observation encoders, where the local
#   variable count mirrors the observation schema being assembled rather
#   than reflecting poor decomposition.
# too-few-public-methods: every plugin base class (RewardFunction,
#   ObservationBuilder) is intentionally single-method by contract.
disable=C0114,C0115,C0116,duplicate-code,protected-access,too-many-locals,too-few-public-methods

[FORMAT]
max-line-length=88
